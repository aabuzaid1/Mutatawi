rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ===================== COURSE THUMBNAILS =====================
    // المستخدمين المسجلين فقط يقدرون يرفعون صور الكورسات
    // الحد الأقصى 10MB + نوع الملف لازم يكون صورة
    match /course-thumbnails/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ===================== GENERATED FILES =====================
    // الملفات المولدة من الذكاء الاصطناعي (مثل تقارير أو عروض تقديمية)
    match /generated/{fileName} {
      allow read: if true;
      allow write: if false; // الرفع مسموح فقط من السيرفر (Admin SDK)
    }

    // ===================== DEFAULT: DENY ALL =====================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
